{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri.js/dev/crates/tauri-cli/schema.json",
  "productName": "PasswordRandom",
  "version": "0.1.0",
  "identifier": "com.passwordrandom.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "密码随机生成器",
        "width": 960,
        "height": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
